  // Books
  "b-1": ["i-semi", "i-hardware", "j-electronics", "j-reading-turn", "n-3", "n-4"],
  "b-2": ["i-startups", "j-whomr", "j-afc", "j-reading-turn", "n-1"],
  "b-3": ["i-design", "j-eonforge", "j-wemus"],

